# Порт веб-сервиса
PORT=8090

# Рабочая директория LightRAG (граф + векторы)
RAG_WORKING_DIR=./data/rag_storage

# Автовозобновление обработки незавершённых документов при старте (может подвешивать UI)
RAG_AUTO_RESUME=false

# Hot-reload uvicorn (удобно при разработке; держите false, если запускаете несколько копий)
RAG_RELOAD=false

# Настройки LLM по умолчанию (можно менять в UI)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2:latest
LLM_API_KEY=ollama

EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_DIM=768
EMBEDDING_API_KEY=ollama
